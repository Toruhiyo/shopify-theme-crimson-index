{%- liquid
  assign layout_style = section.settings.layout_style | default: 'slideshow'
  assign is_flagship = false
  if layout_style == 'flagship'
    assign is_flagship = true
  endif

  assign _default_hero_images = 'hero-new-arrivals.jpg,hero-sale.jpg,hero-clearance.jpg,hero-deal-of-week.jpg,hero-flash-sale.jpg,hero-limited-time.jpg'
  assign _has_block_images = false
  for block in section.blocks
    if block.settings.image != blank
      assign _has_block_images = true
      break
    endif
  endfor
  if _has_block_images
    assign slide_count = section.blocks.size
  elsif section.blocks.size == 0
    assign _fallback_images = _default_hero_images | split: ','
    assign slide_count = _fallback_images.size
  else
    assign slide_count = section.blocks.size
  endif
  assign interval = section.settings.autoplay_interval | times: 1000

-%}

<section
  class="hero{% if is_flagship %} hero--flagship{% endif %}"
  {% unless is_flagship %}
    data-hero-slideshow
    data-autoplay-interval="{{ interval }}"
  {% endunless %}
>
  <div class="hero__slides">
    {%- if is_flagship -%}
      <div class="hero__slide is-active">
        <div class="hero__flagship-inner">
          {%- assign _h = section.settings.flagship_heading | strip -%}
          {%- assign _c = section.settings.flagship_caption | strip -%}
          {%- assign _s = section.settings.flagship_subheading | strip -%}
          <div class="hero__flagship-text">
            {%- if _h != '' -%}
              <h1 class="hero__title">{{ section.settings.flagship_heading }}</h1>
            {%- endif -%}
            {%- if _c != '' -%}
              <p class="hero__subtitle">{{ section.settings.flagship_caption }}</p>
            {%- endif -%}
            {%- if _s != '' -%}
              <p class="hero__subheading">{{ section.settings.flagship_subheading }}</p>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- elsif _has_block_images -%}
      {%- for block in section.blocks -%}
        <div
          class="hero__slide{% if forloop.first %} is-active{% endif %}"
          data-hero-slide="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          <div class="hero__media">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 2000 }}"
                alt="{{ block.settings.image.alt | default: section.settings.title | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                {%- if forloop.first %} fetchpriority="high"{% endif %}
              >
            {%- else -%}
              {%- assign _fb_idx = forloop.index0 | modulo: _fallback_images.size -%}
              <img
                src="{{ _default_hero_images | split: ',' | slice: _fb_idx, 1 | first | asset_url }}"
                alt="{{ section.settings.title | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                {%- if forloop.first %} fetchpriority="high"{% endif %}
              >
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      {%- assign _fallback_images = _default_hero_images | split: ',' -%}
      {%- for img_file in _fallback_images -%}
        <div
          class="hero__slide{% if forloop.first %} is-active{% endif %}"
          data-hero-slide="{{ forloop.index0 }}"
        >
          <div class="hero__media">
            <img
              src="{{ img_file | strip | asset_url }}"
              alt="{{ section.settings.title | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              {%- if forloop.first %} fetchpriority="high"{% endif %}
            >
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- unless is_flagship -%}
    {%- if slide_count > 1 -%}
      <div class="hero__nav" aria-label="Slideshow navigation">
        <button class="hero__arrow hero__arrow--prev" data-hero-prev aria-label="Previous slide">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>

        <div class="hero__dots">
          {%- for i in (1..slide_count) -%}
            <button
              class="hero__dot{% if forloop.first %} is-active{% endif %}"
              data-hero-dot="{{ forloop.index0 }}"
              aria-label="Go to slide {{ forloop.index }}"
            ></button>
          {%- endfor -%}
        </div>

        <button class="hero__arrow hero__arrow--next" data-hero-next aria-label="Next slide">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    {%- endif -%}
  {%- endunless -%}
</section>

{% schema %}
{
  "name": "Hero banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout",
      "options": [
        { "value": "slideshow", "label": "Slideshow" },
        { "value": "flagship", "label": "Text hero (headings)" }
      ],
      "default": "flagship",
      "info": "Text hero: headings only, compact layout. Slideshow uses image slides."
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Auto-rotate interval (seconds)",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "header",
      "content": "Text hero (headings)"
    },
    {
      "type": "text",
      "id": "flagship_heading",
      "label": "Heading",
      "default": "Meridian"
    },
    {
      "type": "text",
      "id": "flagship_caption",
      "label": "Subheading",
      "default": "Premium electronics for your home and workspace."
    },
    {
      "type": "text",
      "id": "flagship_subheading",
      "label": "Supporting line (optional)",
      "default": " "
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Hero banner",
      "settings": {
        "layout_style": "flagship"
      },
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    },
    {
      "name": "Hero (text)",
      "settings": {
        "layout_style": "flagship",
        "flagship_heading": "Meridian",
        "flagship_caption": "Premium electronics for your home and workspace.",
        "flagship_subheading": " "
      },
      "blocks": []
    }
  ]
}
{% endschema %}
