{%- liquid
  assign height_class = ''
  if section.settings.height == 'large'
    assign height_class = 'hero--large'
  endif
-%}

<section class="hero {{ height_class }}">
  <div class="hero__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
    {%- elsif section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 2000 }}"
        alt="{{ section.settings.image.alt | escape }}"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      <img
        src="{{ 'hero-1.jpeg' | asset_url }}"
        alt="{{ section.settings.title | escape }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}
  </div>

  <div class="hero__overlay"></div>

  <div class="page-width hero__container">
    <div class="hero__content">
      {%- if section.settings.subtitle != blank -%}
        <p class="hero__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h1 class="hero__title h0">{{ section.settings.title }}</h1>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="hero__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background video"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Height",
      "options": [
        { "value": "medium", "label": "Medium (70vh)" },
        { "value": "large", "label": "Large (85vh)" }
      ],
      "default": "large"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The best devices. Without the guesswork."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Technology, curated."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
