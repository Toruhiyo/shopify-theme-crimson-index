{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign cta_text = section.settings.cta_text
  assign cta_url = section.settings.cta_url
  assign secondary_text = section.settings.secondary_text
  assign secondary_url = section.settings.secondary_url
  assign show_logo = section.settings.show_logo
-%}

<section class="hero-text" {{ section.shopify_attributes }}>
  <div class="page-width hero-text__inner">
    {%- if show_logo -%}
      <div class="hero-text__logo">
        <img
          src="{{ 'logo-transparent.png' | asset_url }}"
          alt="{{ shop.name }}"
          width="48"
          height="48"
          loading="eager"
        >
      </div>
    {%- endif -%}

    {%- if heading != blank -%}
      <h1 class="hero-text__heading">{{ heading }}</h1>
    {%- endif -%}

    {%- if subheading != blank -%}
      <p class="hero-text__subheading">{{ subheading }}</p>
    {%- endif -%}

    <div class="hero-text__actions">
      {%- if cta_text != blank -%}
        <a href="{{ cta_url }}" class="btn btn--primary hero-text__btn">
          {{ cta_text }}
        </a>
      {%- endif -%}
      {%- if secondary_text != blank -%}
        <a href="{{ secondary_url }}" class="btn btn--outline hero-text__btn">
          {{ secondary_text }}
        </a>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="hero-text__stats">
        {%- for block in section.blocks -%}
          <div class="hero-text__stat" {{ block.shopify_attributes }}>
            <span class="hero-text__stat-value">{{ block.settings.value }}</span>
            <span class="hero-text__stat-label">{{ block.settings.label }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="hero-text__accent" aria-hidden="true"></div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "Show logo",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Technology that moves you forward."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our curated selection of premium electronics — designed for performance, built to last."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Primary button text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary button text",
      "default": "View deals"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary button link"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "10K+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Happy customers"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "value": "10K+",
            "label": "Happy customers"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "500+",
            "label": "Products"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "30-day",
            "label": "Free returns"
          }
        }
      ]
    }
  ]
}
{% endschema %}
