{%- liquid
  assign _heading = section.settings.heading | strip
  if _heading == ''
    assign _heading = shop.name
  endif
  assign _sub = section.settings.subheading | strip
  assign _btn = section.settings.button_label | strip
-%}

<section class="hero-minimal">
  <div class="page-width hero-minimal__inner">
    {%- if section.settings.show_logo -%}
      <div class="hero-minimal__logo-wrap">
        {%- if section.settings.logo_image != blank -%}
          <img
            class="hero-minimal__logo"
            src="{{ section.settings.logo_image | image_url: width: 240 }}"
            alt="{{ section.settings.logo_image.alt | default: shop.name | escape }}"
            width="{{ section.settings.logo_image.width }}"
            height="{{ section.settings.logo_image.height }}"
            loading="eager"
            fetchpriority="high"
          >
        {%- else -%}
          <img
            class="hero-minimal__logo"
            src="{{ 'logo-transparent.png' | asset_url }}"
            alt="{{ shop.name }}"
            width="160"
            height="42"
            loading="eager"
            fetchpriority="high"
          >
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="hero-minimal__copy">
      <h1 class="hero-minimal__heading">{{ _heading }}</h1>
      {%- if _sub != '' -%}
        <p class="hero-minimal__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- if _btn != '' and section.settings.button_link != blank -%}
      <div class="hero-minimal__actions">
        <a class="button button--primary" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "Show logo",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo (optional)",
      "info": "Replaces the default theme logo. Kept small."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": " "
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Curated electronics. Voice-first help when you need it."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label (optional)",
      "default": " "
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
