{%- comment -%}
  Product Links — Renders linked products as variant-like selectors.
  Each linking metafield group shows as a labelled row of swatches or pills.

  Supported metafield keys (list.product_reference, "custom" namespace):
    color_variants      — image swatches (color/finish)
    memory_variants     — text pills (RAM, reads ram_gb metafield)
    storage_variants    — text pills (storage, reads storage_gb metafield)
    config_variants     — text pills (technical configuration)
    size_variants       — text pills (physical size)
    compatible_products — image swatches (complementary products)

  LINK_VALUE_METAFIELDS maps link keys to a product metafield for pill text.
  When set, the pill reads that metafield value directly instead of title parsing.

  To add a new linking metafield, append to KEYS, LABELS, IMAGE_KEYS, and
  optionally VALUE_METAFIELDS.
  Required param: product
{%- endcomment -%}

{%- liquid
  assign LINK_REF_KEYS        = 'color_variants,memory_variants,storage_variants,config_variants,size_variants,compatible_products'
  assign LINK_REF_LABELS       = 'Color,Memory,Internal Storage,Configuration,Size,Compatible with'
  assign LINK_IMAGE_KEYS       = 'color_variants,compatible_products'
  assign LINK_VALUE_METAFIELDS = ',ram_gb,storage_gb,,,'
  assign LINK_VALUE_SUFFIXES   = ', GB, GB,,,'
  assign LINK_MAX_ITEMS        = 12
-%}

{%- assign _ref_keys = LINK_REF_KEYS | split: ',' -%}
{%- assign _ref_labels = LINK_REF_LABELS | split: ',' -%}
{%- assign _val_mfs = LINK_VALUE_METAFIELDS | split: ',' -%}
{%- assign _val_suffixes = LINK_VALUE_SUFFIXES | split: ',' -%}
{%- assign _separator = ' — ' -%}

{%- for idx in (0..9) -%}
  {%- if idx >= _ref_keys.size -%}{%- break -%}{%- endif -%}
  {%- assign _key = _ref_keys[idx] | strip -%}
  {%- if _key == blank -%}{%- continue -%}{%- endif -%}
  {%- assign _label = _ref_labels[idx] | strip -%}
  {%- assign _refs = product.metafields.custom[_key].value -%}
  {%- assign _use_image = false -%}
  {%- if LINK_IMAGE_KEYS contains _key -%}
    {%- assign _use_image = true -%}
  {%- endif -%}
  {%- assign _val_mf = _val_mfs[idx] | strip -%}
  {%- assign _val_suffix = _val_suffixes[idx] | strip -%}

  {%- if _refs != blank -%}
    {%- assign _valid_count = 0 -%}
    {%- for _ref in _refs -%}
      {%- if _ref != blank and _ref.handle != blank -%}
        {%- assign _valid_count = _valid_count | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if _valid_count > 1 -%}
      <div class="pdp__variants mb-md">
        <p class="pdp__variant-label">{{ _label }}</p>
        <div class="product-link-group" data-product-link-group>
          {%- assign _rendered = 0 -%}
          {%- assign _seen_values = '' -%}
          {%- for _ref in _refs -%}
            {%- if _rendered >= LINK_MAX_ITEMS -%}{%- break -%}{%- endif -%}
            {%- if _ref == blank or _ref.handle == blank -%}{%- continue -%}{%- endif -%}

            {%- comment -%} Compute display value for dedup {%- endcomment -%}
            {%- if _use_image -%}
              {%- assign _display_val = _ref.metafields.custom.variant_color.value | default: '' -%}
              {%- if _display_val == blank -%}
                {%- assign _title_segs = _ref.title | split: _separator -%}
                {%- if _title_segs.size > 1 -%}
                  {%- assign _display_val = _title_segs[1] -%}
                {%- else -%}
                  {%- assign _display_val = _ref.title -%}
                {%- endif -%}
              {%- endif -%}
            {%- elsif _val_mf != blank -%}
              {%- assign _raw_val = _ref.metafields.custom[_val_mf].value -%}
              {%- if _raw_val != blank -%}
                {%- assign _num = _raw_val | times: 1 -%}
                {%- if _num >= 1024 -%}
                  {%- assign _tb = _num | divided_by: 1024 -%}
                  {%- assign _display_val = _tb | append: ' TB' -%}
                {%- else -%}
                  {%- assign _display_val = _num | append: ' ' | append: _val_suffix -%}
                {%- endif -%}
              {%- else -%}
                {%- assign _title_parts = _ref.title | split: _separator -%}
                {%- assign _display_val = _title_parts | last -%}
              {%- endif -%}
            {%- else -%}
              {%- assign _title_parts = _ref.title | split: _separator -%}
              {%- assign _display_val = _title_parts | last -%}
            {%- endif -%}

            {%- assign _dedup_key = _display_val | strip | downcase -%}
            {%- assign _dedup_token = '||' | append: _dedup_key | append: '||' -%}
            {%- if _seen_values contains _dedup_token -%}{%- continue -%}{%- endif -%}
            {%- assign _seen_values = _seen_values | append: _dedup_token -%}

            {%- assign _is_current = false -%}
            {%- if _ref.id == product.id -%}{%- assign _is_current = true -%}{%- endif -%}

            <a
              href="{{ _ref.url }}"
              class="{% if _use_image %}product-link-swatch{% else %}product-link-pill{% endif %}{% if _is_current %} is-active{% endif %}"
              aria-label="{{ _ref.title }}"
              title="{{ _ref.title }}"
              data-product-link
            >
              {%- if _use_image -%}
                {%- if _ref.featured_image -%}
                  <img
                    src="{{ _ref.featured_image | image_url: width: 140 }}"
                    alt="{{ _ref.title | escape }}"
                    loading="lazy"
                    width="70"
                    height="70"
                  >
                {%- endif -%}
                <span class="product-link-swatch__label">{{ _display_val }}</span>
              {%- else -%}
                {{- _display_val -}}
              {%- endif -%}
            </a>
            {%- assign _rendered = _rendered | plus: 1 -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
